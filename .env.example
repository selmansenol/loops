# ---------------------------------------------------------------------------
# Loop configuration. Copy this file to `.env` and fill in the values.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Postgres connection string.
# Local dev:           postgres://postgres:postgres@localhost:5432/loop
# Docker Compose uses: postgres://postgres:postgres@db:5432/loop  (set in compose)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/loop"

# Optional connection pool size (default 10).
# DATABASE_POOL_MAX=10

# Only for the production stack (docker-compose.prod.yml): the Postgres password.
# DATABASE_URL above is derived from it inside that compose file.
POSTGRES_PASSWORD="change-me-strong-password"

# ---------------------------------------------------------------------------
# Auth (better-auth)
# ---------------------------------------------------------------------------
# Random 32+ byte secret used to sign sessions. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of the app (used for OAuth callbacks & cookies).
BETTER_AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Social login (optional). Leave blank to disable a provider; email/password
# always works. Callback URL to register with each provider:
#   <BETTER_AUTH_URL>/api/auth/callback/google
#   <BETTER_AUTH_URL>/api/auth/callback/github
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Email (optional, via Resend). When RESEND_API_KEY is set, Loops requires
# email verification on sign-up and enables password reset. Leave blank to keep
# sign-in open with no email (fine for self-host / local dev).
#   Get a key at https://resend.com, verify your domain, then set:
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Loops <noreply@getloops.co>"

# ---------------------------------------------------------------------------
# AI provider keys (optional). Used by the AI Insights feature. Keys can also
# be set at runtime from Settings → AI (stored in the DB, which takes priority).
# ---------------------------------------------------------------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Optional: force a provider/model instead of auto-selecting.
# LOOP_AI_PROVIDER="anthropic"   # openai | anthropic | google
# LOOP_AI_MODEL="claude-3-5-haiku-latest"

# ---------------------------------------------------------------------------
# Tenancy
# ---------------------------------------------------------------------------
# Leave UNSET for multi-tenant mode (getloops.co style): `/` is the marketing
# landing and each board lives at `/<slug>`.
#
# Set SINGLE_TENANT_SLUG to run as a single board (the open-source self-host
# experience): the app exposes one workspace at that slug, `/` redirects to it,
# the first user to sign in becomes its owner, and everyone after joins as a
# member. The workspace switcher / dashboard / "new board" UI is hidden.
# SINGLE_TENANT_SLUG="main"

# Optional: in multi-tenant mode, the slug the landing "Try the live demo"
# button (and /demo) redirects to. Leave unset to send visitors to /dashboard.
# DEMO_WORKSPACE_SLUG="demo"

# Optional: max boards a single user may create (free-tier cap). Unset or 0 =
# unlimited (the self-host default). On the hosted plan, e.g. 3.
# FREE_TIER_MAX_BOARDS="3"

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# PORT=3000
